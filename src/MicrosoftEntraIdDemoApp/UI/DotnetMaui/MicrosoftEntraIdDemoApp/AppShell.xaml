<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MicrosoftEntraIdDemoApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loginFeature="clr-namespace:MicrosoftEntraIdDemoApp.Logic.Features;assembly=MicrosoftEntraIdDemoApp.Logic"
    xmlns:userCheckFeature="clr-namespace:MicrosoftEntraIdDemoApp.Logic.Features.UserCheck;assembly=MicrosoftEntraIdDemoApp.Logic"
    xmlns:authTestFeature="clr-namespace:MicrosoftEntraIdDemoApp.Logic.Features.AuthTest;assembly=MicrosoftEntraIdDemoApp.Logic"
    Title="MicrosoftEntraIdDemoApp">

    <Shell.ToolbarItems>
        <ToolbarItem
        Text="Logout"
        Command="{Binding LogoutCommand}" />
    </Shell.ToolbarItems>

    <ShellContent
        Title="Login Page"
        ContentTemplate="{DataTemplate loginFeature:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        Title="User Information"
        ContentTemplate="{DataTemplate userCheckFeature:UserCheckPage}"
        Route="UserCheckPage" />

    <ShellContent
        Title="Authentication Test"
        ContentTemplate="{DataTemplate authTestFeature:AuthTestPage}"
        Route="AuthTestPage" />

</Shell>
